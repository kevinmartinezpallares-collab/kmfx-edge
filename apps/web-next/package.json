{
  "name": "web-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next/dev",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "qa:mobile:v1": "node scripts/audit-v1-mobile.mjs",
    "qa:screenshots:v1": "node scripts/capture-v1-qa-screenshots.mjs",
    "qa:live:snapshot": "node scripts/audit-live-snapshot.mjs",
    "qa:live:integrity": "node scripts/audit-live-integrity.mjs",
    "preflight:beta": "python3 ../../scripts/next_beta_preflight.py --scope student",
    "preflight:platform": "python3 ../../scripts/next_beta_preflight.py --scope platform",
    "preflight:full": "python3 ../../scripts/next_beta_preflight.py --scope full",
    "deploy:beta": "python3 ../../scripts/deploy_next_beta.py",
    "monitor:beta": "python3 ../../scripts/beta_monitor_usage.py",
    "test:smoke:routes": "node scripts/smoke-workspace-routes.mjs",
    "typecheck": "tsc --noEmit --pretty false",
    "validate": "npm run test && npm run typecheck && npm run lint",
    "validate:cascade": "npm run test -- migration-scope package-contract workspace-source-contract kmfx-api-config shell-contract action-safety v1-readiness-contract live-snapshot-adapter live-snapshot-readiness navigation visible-copy theme-contract dashboard-selectors calendar-selectors analytics-selectors accounts-selectors portfolio-selectors trades-selectors settings-selectors && npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@number-flow/react": "^0.6.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@visx/curve": "^4.0.1-alpha.0",
    "@visx/event": "^4.0.1-alpha.0",
    "@visx/grid": "^4.0.1-alpha.0",
    "@visx/group": "^4.0.1-alpha.0",
    "@visx/responsive": "^4.0.1-alpha.0",
    "@visx/scale": "^4.0.1-alpha.0",
    "@visx/shape": "^4.0.1-alpha.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-array": "^3.2.4",
    "d3-shape": "^3.2.0",
    "liveline": "^0.0.7",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "tailwindcss": "4.3.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
