{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "node apps/web-next/scripts/vercel-ignore-build.mjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.kmfxedge.com"
        }
      ],
      "destination": "https://kmfxedge.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "dashboard.kmfxedge.com"
        }
      ],
      "destination": "https://kmfxedge.com/:path*",
      "permanent": true
    },
    {
      "source": "/kmfx-edge.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/discipline",
      "destination": "/execution",
      "permanent": true
    },
    {
      "source": "/connections",
      "destination": "/accounts",
      "permanent": true
    },
    {
      "source": "/calculator",
      "destination": "/tools/calculator",
      "permanent": true
    },
    {
      "source": "/configuracion",
      "destination": "/settings",
      "permanent": true
    },
    {
      "source": "/portfolio",
      "destination": "/capital",
      "permanent": true
    },
    {
      "source": "/funded",
      "destination": "/funding",
      "permanent": true
    },
    {
      "source": "/glossary",
      "destination": "/study",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/refunds",
      "destination": "/refunds.html"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    }
  ],
  "headers": [
    {
      "source": "/kmfx-sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/downloads/KMFX-Launcher-Windows.exe",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"KMFX-Launcher-Windows.exe\""
        }
      ]
    },
    {
      "source": "/downloads/KMFX-Launcher-mac.dmg",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"KMFX-Launcher-mac.dmg\""
        }
      ]
    },
    {
      "source": "/downloads/KMFX-Launcher-macOS.zip",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"KMFX-Launcher-macOS.zip\""
        }
      ]
    },
    {
      "source": "/downloads/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://kmfxedge.com"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://kmfxedge.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://checkout.stripe.com https://billing.stripe.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://esm.sh https://s3.tradingview.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://kmfx-edge-api.onrender.com wss://kmfx-edge-api.onrender.com https://mt5-api.kmfxedge.com wss://mt5-api.kmfxedge.com https://challenges.cloudflare.com https://checkout.stripe.com https://billing.stripe.com; frame-src https://challenges.cloudflare.com https://checkout.stripe.com https://billing.stripe.com https://www.tradingview.com; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://kmfxedge.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://checkout.stripe.com https://billing.stripe.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://esm.sh https://s3.tradingview.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://kmfx-edge-api.onrender.com wss://kmfx-edge-api.onrender.com https://mt5-api.kmfxedge.com wss://mt5-api.kmfxedge.com https://challenges.cloudflare.com https://checkout.stripe.com https://billing.stripe.com; frame-src https://challenges.cloudflare.com https://checkout.stripe.com https://billing.stripe.com https://www.tradingview.com; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
