{
  "version": "1.0.0",
  "updated_at": "2026-05-08",
  "accounting_timezone": "Europe/Andorra",
  "principles": [
    "A metric can be shown as operational only when its source and formula are explicit.",
    "A configured policy can create warning or breach states; a default/reference assumption cannot.",
    "Positions without stop loss are unbounded risk, not zero risk.",
    "MT5 identifiers are strings end to end to avoid truncation or JavaScript precision loss.",
    "Tail risk and simulation metrics must expose method, assumptions, sample size, and sample quality."
  ],
  "metrics": [
    {
      "id": "balance",
      "label": "Balance",
      "source": "EA AccountInfoDouble(ACCOUNT_BALANCE)",
      "formula": "latest account balance",
      "unit": "account_currency",
      "confidence": "high",
      "policy_source": "none",
      "refresh": "live_sync",
      "visual": "kpi_and_equity_area"
    },
    {
      "id": "equity",
      "label": "Equity",
      "source": "EA AccountInfoDouble(ACCOUNT_EQUITY)",
      "formula": "balance + open floating result",
      "unit": "account_currency",
      "confidence": "high",
      "policy_source": "none",
      "refresh": "live_sync",
      "visual": "kpi_and_equity_area"
    },
    {
      "id": "floating_pnl",
      "label": "Floating PnL",
      "source": "EA POSITION_PROFIT + POSITION_SWAP, fallback ACCOUNT_PROFIT",
      "formula": "sum(position.floating_pnl)",
      "unit": "account_currency",
      "confidence": "high_when_position_payload_present",
      "policy_source": "none",
      "refresh": "live_sync",
      "visual": "kpi_badge"
    },
    {
      "id": "net_profit",
      "label": "Net Profit",
      "source": "Backend normalized closed trades",
      "formula": "sum(profit + commission + swap + dividend)",
      "unit": "account_currency",
      "confidence": "high_when_mt5_history_complete",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "kpi_and_cumulative_line"
    },
    {
      "id": "gross_profit_factor",
      "label": "Gross Profit Factor",
      "source": "Backend closed trade profit component",
      "formula": "sum(max(profit, 0)) / abs(sum(min(profit, 0)))",
      "unit": "ratio",
      "confidence": "high_when_mt5_history_complete",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "detail_ratio"
    },
    {
      "id": "net_profit_factor",
      "label": "Net Profit Factor",
      "source": "Backend closed trade net result",
      "formula": "sum(max(net, 0)) / abs(sum(min(net, 0)))",
      "unit": "ratio",
      "confidence": "high_when_mt5_history_complete",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "primary_edge_kpi"
    },
    {
      "id": "total_open_risk_pct",
      "label": "Total Open Risk",
      "source": "EA risk_amount/risk_pct per position",
      "formula": "sum(calculable position risk_pct); unbounded positions are counted separately",
      "unit": "percent",
      "confidence": "high_only_when_all_positions_have_stop_loss",
      "policy_source": "configured_policy_required_for_breach",
      "refresh": "live_sync",
      "visual": "risk_bar_with_unbounded_warning"
    },
    {
      "id": "missing_stop_loss_positions_count",
      "label": "Positions Without SL",
      "source": "EA position.sl and risk_state",
      "formula": "count(position where risk_state in missing_stop_loss/unbounded)",
      "unit": "count",
      "confidence": "high",
      "policy_source": "none",
      "refresh": "live_sync",
      "visual": "warning_badge"
    },
    {
      "id": "daily_drawdown_pct",
      "label": "Daily Drawdown",
      "source": "Backend persisted daily peak equity",
      "formula": "(daily_peak_equity - equity) / daily_peak_equity * 100",
      "unit": "percent",
      "confidence": "high_after_first_daily_sync",
      "policy_source": "configured_policy_required_for_breach",
      "refresh": "live_sync",
      "visual": "progress_bar"
    },
    {
      "id": "peak_to_equity_drawdown_pct",
      "label": "Peak To Equity Drawdown",
      "source": "Backend persisted peak equity",
      "formula": "(persisted_peak_equity - equity) / persisted_peak_equity * 100",
      "unit": "percent",
      "confidence": "high_after_persisted_history",
      "policy_source": "configured_policy_required_for_breach",
      "refresh": "live_sync",
      "visual": "drawdown_area"
    },
    {
      "id": "historical_var_95",
      "label": "Historical VaR 95",
      "source": "Backend normalized closed trade returns",
      "formula": "95th percentile of the historical loss distribution where loss = -closed_trade_net_pnl",
      "unit": "account_currency_or_percent",
      "confidence": "directional_below_30_samples",
      "method": "historical",
      "assumptions": [
        "Past closed trades are representative of the current trading style.",
        "Closed trades are complete for the selected sync window.",
        "Does not assume a normal distribution."
      ],
      "sample_quality": "0 = sin_muestra, <30 = insuficiente, 30-99 = aceptable, >=100 = robusta",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "radial_with_sample_size"
    },
    {
      "id": "parametric_var_95",
      "label": "Parametric VaR 95",
      "source": "Backend normalized closed trade net PnL",
      "formula": "mean_loss + standard_deviation(pnl) * normal_z_score(confidence)",
      "unit": "account_currency",
      "confidence": "requires_at_least_30_samples_and_is_model_based",
      "method": "parametric_normal",
      "assumptions": [
        "Trade PnL distribution is approximated by a normal distribution.",
        "Volatility of the historical sample remains relevant.",
        "Used as technical detail, not as primary dashboard truth when sample is small."
      ],
      "sample_quality": "0 = sin_muestra, <30 = unavailable, 30-99 = aceptable, >=100 = robusta",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "technical_detail"
    },
    {
      "id": "monte_carlo_var_95",
      "label": "Monte Carlo VaR 95",
      "source": "Backend bootstrap from normalized closed trade net PnL",
      "formula": "bootstrap simulated trade paths, then historical VaR over simulated outcomes",
      "unit": "account_currency_or_percent",
      "confidence": "directional_below_30_samples",
      "method": "monte_carlo_bootstrap",
      "assumptions": [
        "Future trades can be sampled from the historical closed-trade distribution.",
        "Does not predict new market regimes or strategy drift.",
        "Seeded simulations must be deterministic for QA."
      ],
      "sample_quality": "0 = sin_muestra, <30 = insuficiente, 30-99 = aceptable, >=100 = robusta",
      "policy_source": "none",
      "refresh": "sync_window",
      "visual": "histogram_or_radial_with_sample_size"
    },
    {
      "id": "risk_of_ruin",
      "label": "Risk Of Ruin",
      "source": "Backend risk_math analytical model plus Monte Carlo context",
      "formula": "analytical Brownian approximation from win rate, payoff ratio, risk per trade, and ruin threshold",
      "unit": "probability_percent",
      "confidence": "directional_until_sample_size_sufficient",
      "method": "analytical_brownian",
      "assumptions": [
        "Each trade is approximated as +payoff_ratio R or -1R.",
        "Risk per trade comes from configured policy when available; otherwise average loss to equity.",
        "If expectancy is non-positive, eventual ruin is treated as 100% to avoid optimistic false reads."
      ],
      "sample_quality": "0 = unavailable, <30 = low, 30-99 = medium, >=100 = high",
      "policy_source": "configured_or_reference_assumption_visible",
      "refresh": "sync_window",
      "visual": "radial_with_assumptions"
    }
  ]
}
