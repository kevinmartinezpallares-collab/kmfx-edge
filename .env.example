# KMFX Edge future Next.js billing/auth environment.
# Copy values into the real deployment environment, never into committed files.

NEXT_PUBLIC_APP_URL=http://localhost:3000
KMFX_ENV=development

# Next.js V1 read-only account beta.
# Keep these unset unless testing the parallel Next app against a preview API.
KMFX_API_BASE_URL=
NEXT_PUBLIC_KMFX_API_BASE_URL=
KMFX_WAVE1_SOURCE=fixture
KMFX_SNAPSHOT_TIMEOUT_MS=8000
KMFX_PREVIEW_BEARER_TOKEN=
KMFX_PREVIEW_USER_EMAIL=
KMFX_PREVIEW_USER_ID=

# Macro calendar / News Risk.
# Uses an official embeddable widget, no API key and no owned event data in V1.
NEXT_PUBLIC_MACRO_CALENDAR_ENABLED=true
NEXT_PUBLIC_MACRO_CALENDAR_PROVIDER=tradingview

# Backend CORS. Production defaults allow only KMFX Edge domains.
# Keep localhost enabled only for local development.
KMFX_CORS_ALLOW_ORIGINS=https://kmfxedge.com,https://www.kmfxedge.com,https://dashboard.kmfxedge.com
KMFX_ALLOW_LOCAL_CORS=true
KMFX_BLOCK_LEGACY_DASHBOARD_LIVE=false
KMFX_FEATURE_DIRECT_MT5=false

# Backend admin access. Production has no admin fallback; configure real values in Render.
KMFX_ADMIN_USER_IDS=
KMFX_ADMIN_EMAILS=
KMFX_ADMIN_LAUNCHER_CONNECTION_KEYS=
KMFX_ENABLE_DEV_ADMIN_FALLBACK=false

NEXT_PUBLIC_SUPABASE_URL=https://uuhiqreifisppqkawzif.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_PRODUCT_ID=prod_UT7nzmgj3Eg3Zv
STRIPE_TRIAL_PERIOD_DAYS=7
STRIPE_TRIAL_REQUIRES_CARD=false

# Current production-safe contract: use live Price IDs until Stripe lookup keys are configured.
STRIPE_PRICE_CORE_MONTHLY=price_1TUBYUEoC6e7wNItXEGCdVZ4
STRIPE_PRICE_CORE_YEARLY=price_1TUC1ZEoC6e7wNItpQF7UGPA
STRIPE_PRICE_PRO_MONTHLY=price_1TULXwEoC6e7wNItP3e4pCh4
STRIPE_PRICE_PRO_YEARLY=price_1TULY0EoC6e7wNItYVKQKHIi
STRIPE_PRICE_UNLIMITED_MONTHLY=price_1TUC5uEoC6e7wNItcPyjGy5Z
STRIPE_PRICE_UNLIMITED_YEARLY=price_1TUC65EoC6e7wNItBfoMCblt

BILLING_SUCCESS_PATH=/ajustes?tab=subscription&checkout=success&session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_PATH=/ajustes?tab=subscription&checkout=cancelled

# Emergency bandwidth guard. Production defaults to lockdown while this is true.
KMFX_BANDWIDTH_EMERGENCY_LOCKDOWN=true
KMFX_BANDWIDTH_FORCE_MODE=hard
KMFX_BANDWIDTH_HARD_SYNC_INTERVAL_SECONDS=300
KMFX_BANDWIDTH_CRITICAL_SYNC_INTERVAL_SECONDS=180
KMFX_BANDWIDTH_SAVING_SYNC_INTERVAL_SECONDS=120
KMFX_BANDWIDTH_NORMAL_SYNC_INTERVAL_SECONDS=60

# MT5 payload limits. These keep legacy/full-history connectors from creating
# large Supabase writes or service-initiated bandwidth spikes.
KMFX_MT5_SYNC_MAX_BODY_BYTES=524288
KMFX_MT5_JOURNAL_MAX_BODY_BYTES=262144
KMFX_MT5_SYNC_MAX_POSITIONS=50
KMFX_MT5_SYNC_MAX_TRADES=40
KMFX_MT5_SYNC_MAX_HISTORY_POINTS=48
KMFX_STORE_FULL_MT5_PAYLOADS=false
KMFX_MAX_STORED_OPEN_POSITIONS=25
KMFX_MAX_STORED_TRADES=40
KMFX_MAX_STORED_HISTORY_POINTS=48

# Backend rate limits. Set to 0 only for local debugging.
KMFX_CONNECTION_RATE_LIMIT_SYNC_PER_MINUTE=1
KMFX_CONNECTION_RATE_LIMIT_JOURNAL_PER_MINUTE=1
KMFX_CONNECTION_RATE_LIMIT_POLICY_PER_MINUTE=1
KMFX_RATE_LIMIT_ACCOUNT_WRITE_PER_MINUTE=20
KMFX_RATE_LIMIT_ACCOUNT_KEY_PER_MINUTE=10
KMFX_RATE_LIMIT_BILLING_CHECKOUT_PER_MINUTE=10
KMFX_RATE_LIMIT_BILLING_PORTAL_PER_MINUTE=12
KMFX_RATE_LIMIT_ADMIN_PER_MINUTE=120

# Backend cache knobs to reduce repeated Supabase/Auth egress without caching
# full account snapshots. Keep conservative until production telemetry is stable.
KMFX_VERIFIED_BEARER_CACHE_TTL_SECONDS=300
KMFX_ACCOUNTS_SUMMARY_CACHE_TTL_SECONDS=5
KMFX_ACCOUNTS_SUMMARY_CACHE_MAX_ENTRIES=128
