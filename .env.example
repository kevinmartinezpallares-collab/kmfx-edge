# KMFX Edge future Next.js billing/auth environment.
# Copy values into the real deployment environment, never into committed files.

NEXT_PUBLIC_APP_URL=http://localhost:3000
KMFX_ENV=development

# Backend CORS. Production defaults allow only KMFX Edge domains.
# Keep localhost enabled only for local development.
KMFX_CORS_ALLOW_ORIGINS=https://kmfxedge.com,https://www.kmfxedge.com,https://dashboard.kmfxedge.com
KMFX_ALLOW_LOCAL_CORS=true

NEXT_PUBLIC_SUPABASE_URL=https://uuhiqreifisppqkawzif.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover

STRIPE_PRICE_CORE_MONTHLY=kmfx_core_monthly
STRIPE_PRICE_CORE_YEARLY=kmfx_core_yearly
STRIPE_PRICE_PRO_MONTHLY=kmfx_pro_monthly
STRIPE_PRICE_PRO_YEARLY=kmfx_pro_yearly

BILLING_SUCCESS_PATH=/settings/billing?checkout=success
BILLING_CANCEL_PATH=/settings/billing?checkout=cancelled
